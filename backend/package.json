{
  "name": "youtube-recommender-backend",
  "version": "1.0.0",
  "description": "Backend API for YouTube video recommender extension",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "youtube",
    "recommender",
    "api",
    "chrome-extension"
  ],
  "author": "shubhamcodecc-ctrl",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.1.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express-validator": "^7.0.0",
    "helmet": "^7.0.0",
    "express-rate-limit": "^7.0.0",
    "axios": "^1.5.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/node": "^20.8.0",
    "@types/jest": "^29.5.5",
    "@types/jsonwebtoken": "^9.0.4",
    "typescript": "^5.2.2",
    "ts-node": "^10.9.1",
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.12",
    "eslint": "^8.50.0",
    "@typescript-eslint/parser": "^6.7.2",
    "@typescript-eslint/eslint-plugin": "^6.7.2",
    "prettier": "^3.0.3"
  }
}
